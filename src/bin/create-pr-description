#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# create-pr-description
# Generates PR descriptions using LLM APIs (OpenRouter/Groq)
# from git context, with clickable Azure DevOps PR links.
# ============================================================

VERSION="2.8.1"
CONFIG_DIR="$HOME/.config/pr-tools"
ENV_FILE="$CONFIG_DIR/.env"
TEMPLATE_FILE="$CONFIG_DIR/pr-template.md"
CACHE_FILE="$CONFIG_DIR/.cache"

REPO_URL="https://raw.githubusercontent.com/nitoba/pr-tools/main"

# ---- Source libs ----
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib/pr-tools"
if [[ ! -d "$LIB_DIR" ]]; then
  LIB_DIR="${SCRIPT_DIR}/../lib"
fi

# Auto-download libs if missing (handles upgrade from monolithic version)
_pr_tools_ensure_libs() {
  local missing=false
  for _lib in common.sh llm.sh azure.sh test-card-azure.sh test-card-llm.sh ui.sh; do
    [[ ! -f "$LIB_DIR/$_lib" ]] && missing=true && break
  done
  if [[ "$missing" == "true" ]]; then
    echo "[INFO] Bibliotecas não encontradas. Baixando automaticamente..." >&2
    mkdir -p "$LIB_DIR"
    for _lib in common.sh llm.sh azure.sh test-card-azure.sh test-card-llm.sh ui.sh; do
      if ! curl -fsSL "$REPO_URL/src/lib/$_lib" -o "$LIB_DIR/$_lib" 2>/dev/null; then
        echo "[ERRO] Falha ao baixar $LIB_DIR/$_lib" >&2
        echo "[ERRO] Execute: curl -fsSL $REPO_URL/install.sh | bash" >&2
        exit 1
      fi
    done
    echo "[OK] Bibliotecas instaladas em $LIB_DIR" >&2
  fi
}
_pr_tools_ensure_libs

for _lib in common.sh llm.sh azure.sh; do
  source "$LIB_DIR/$_lib"
done
source "$LIB_DIR/ui.sh"

# Default provider config
DEFAULT_PROVIDERS="openrouter,groq,gemini"
DEFAULT_OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
DEFAULT_GROQ_MODEL="llama-3.3-70b-versatile"
DEFAULT_GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# Global state
BRANCH_NAME=""
GIT_DIFF=""
GIT_LOG=""
SPRINT_NUMBER=""
SPRINT_BRANCH=""
AZURE_ORG=""
AZURE_PROJECT=""
AZURE_REPO=""
AZURE_REPO_ID=""
IS_AZURE_DEVOPS=false
PR_LINKS=()
USED_PROVIDER=""
USED_MODEL=""
LLM_RESULT=""
CLIP_CMD=""
WORK_ITEM_ID=""
CLI_WORK_ITEM=""
SOURCE_BRANCH=""
STREAM_MODE=false

# ---- Default Template ----

DEFAULT_TEMPLATE='Analise o diff e log do git fornecidos e gere um TITULO e uma DESCRIÇÃO de PR
em portugues brasileiro.

IMPORTANTE: A PRIMEIRA LINHA da sua resposta DEVE ser o titulo neste formato exato:
TITULO: <texto curto e descritivo, max 80 caracteres>

Depois do titulo, siga este formato para a descricao:

## Descrição

<Resumo conciso em 1-2 frases do que a mudanca faz e por que>

## Alteracoes

### Componentes atualizados

<Para cada componente/arquivo modificado significativamente, liste:>
- **nome-do-componente**: <Descrição das mudancas neste componente, focando no
  que mudou funcionalmente, não linha por linha>

### Correcoes / Melhorias tecnicas

<Se houver correcoes de bugs, refatoracoes ou melhorias tecnicas, liste aqui.
Se não houver, omita esta secao.>

## Tipo de mudanca

<Marque com [x] os tipos que se aplicam, baseado na analise do diff:>

- [ ] Bug fix
- [ ] Nova feature
- [ ] Breaking change
- [ ] Refactoring

---

## Regras:
- A primeira linha DEVE ser o titulo no formato: TITULO: <texto>
- Se um Work Item for fornecido no contexto (#numero), inclua "Relacionado a: #numero" no final da descricao
- Escreva em portugues brasileiro
- Seja tecnico mas conciso
- Foque no "o que" e "por que", não no "como"
- Use nomes reais de componentes/arquivos do diff
- Se o diff for muito grande, agrupe mudancas relacionadas
- Não invente mudancas que não estao no diff'

# ---- Default .env ----

DEFAULT_ENV='# Providers em ordem de prioridade (tenta o primeiro, se falhar vai pro proximo)
PR_PROVIDERS="openrouter,groq"

# API Keys (descomente e preencha)
# OPENROUTER_API_KEY="sk-or-..."
# GROQ_API_KEY="gsk_..."

# Modelos (opcional - usa padrao gratuito se não definir)
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# GROQ_MODEL="llama-3.3-70b-versatile"

# Streaming (exibe tokens em tempo real; padrao: false)
PR_STREAM="false"

# Azure DevOps (para gerar links de PR com repositoryId)
# AZURE_PAT="your-pat-token"'

# ---- CLI Argument Parsing ----

ACTION=""
TARGETS=()
DRY_RUN=false
RAW_OUTPUT=false
MD_RENDERER_CMD=""

show_help() {
  cat <<'HELP'
create-pr-description [opcoes]

Gera descricao de PR automaticamente a partir do contexto git,
usando LLM (OpenRouter/Groq) com fallback configuravel.

Opcoes:
  --init                              Inicializa arquivos de configuracao
  --source <branch>                    Branch de origem do PR (padrao: branch atual)
  --target <branch>                   Target do PR: dev, sprint (pode repetir; padrao: ambos)
  --work-item <id>                     ID do work item do Azure DevOps (ex: 11763)
  --set-openrouter-model <modelo>     Salva modelo do OpenRouter no .env
  --set-groq-model <modelo>           Salva modelo do Groq no .env
  --set-gemini-model <modelo>         Salva modelo do Google Gemini no .env
  --dry-run                           Mostra o prompt sem chamar a LLM
  --raw                               Exibe a descricao sem renderizacao Markdown (texto puro)
  --no-stream                          Desabilita streaming (exibe resposta apenas ao final)
  --update                            Atualiza o script para a versao mais recente
  --help                              Mostra esta ajuda
  --version                           Mostra a versao

Exemplos:
  create-pr-description                                                # PR para dev + sprint
  create-pr-description --target dev                                   # PR apenas para dev
  create-pr-description --dry-run                                      # Ve o prompt sem chamar LLM
  create-pr-description --set-openrouter-model qwen/qwen3-4b:free     # Muda modelo OpenRouter
  create-pr-description --source feature/1234-login                     # PR usando outra branch como origem
  create-pr-description --update                                       # Atualiza para ultima versao
HELP
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --init)
        ACTION="init"
        shift
        ;;
      --source)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --source requer o nome da branch de origem."
          exit 1
        fi
        SOURCE_BRANCH="$2"
        shift 2
        ;;
      --target)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --target requer um argumento (dev ou sprint)."
          exit 1
        fi
        if [[ "$2" != "dev" && "$2" != "sprint" ]]; then
          log_error "Valor invalido para --target: '$2'. Use 'dev' ou 'sprint'."
          exit 1
        fi
        TARGETS+=("$2")
        shift 2
        ;;
      --work-item)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --work-item requer o ID do work item."
          exit 1
        fi
        CLI_WORK_ITEM="$2"
        shift 2
        ;;
      --set-openrouter-model)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --set-openrouter-model requer o nome do modelo."
          exit 1
        fi
        set_env_var "OPENROUTER_MODEL" "$2"
        log_success "Modelo OpenRouter salvo: $2"
        exit 0
        ;;
      --set-groq-model)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --set-groq-model requer o nome do modelo."
          exit 1
        fi
        set_env_var "GROQ_MODEL" "$2"
        log_success "Modelo Groq salvo: $2"
        exit 0
        ;;
      --set-gemini-model)
        if [[ -z "${2:-}" ]]; then
          log_error "Flag --set-gemini-model requer o nome do modelo."
          exit 1
        fi
        set_env_var "GEMINI_MODEL" "$2"
        log_success "Modelo Gemini salvo: $2"
        exit 0
        ;;
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --raw)
        RAW_OUTPUT=true
        shift
        ;;
      --no-stream)
        STREAM_MODE=false
        shift
        ;;
      --update)
        do_update "create-pr-description" "$VERSION" "$REPO_URL"
        exit 0
        ;;
      --help)
        show_help
        exit 0
        ;;
      --version)
        echo "create-pr-description v$VERSION"
        exit 0
        ;;
      *)
        log_error "Opção desconhecida: $1"
        show_help
        exit 1
        ;;
    esac
  done

  # Default: both targets
  if [[ ${#TARGETS[@]} -eq 0 ]]; then
    TARGETS=("dev" "sprint")
  fi

  # Remove duplicates
  local unique_targets=()
  local seen=""
  for t in "${TARGETS[@]}"; do
    if [[ "$seen" != *"$t"* ]]; then
      unique_targets+=("$t")
      seen="$seen $t"
    fi
  done
  TARGETS=("${unique_targets[@]}")
}

# ---- Init ----

run_setup_wizard() {
  echo ""
  echo -e "${BOLD}========================================${NC}"
  echo -e "${BOLD}  Configuracao interativa${NC}"
  echo -e "${BOLD}========================================${NC}"
  echo ""

  # Load existing values if .env exists
  local existing_providers=""
  local existing_openrouter_key=""
  local existing_groq_key=""
  local existing_gemini_key=""
  local existing_openrouter_model=""
  local existing_groq_model=""
  local existing_gemini_model=""
  local existing_azure_pat=""
  local existing_reviewer_dev=""
  local existing_reviewer_sprint=""
  local is_update=false

  if [[ -f "$ENV_FILE" ]]; then
    is_update=true
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ -z "${line// /}" ]] && continue
      local key="${line%%=*}"
      local value="${line#*=}"
      key=$(echo "$key" | xargs)
      value="${value#\"}" && value="${value%\"}"
      value="${value#\'}" && value="${value%\'}"
      case "$key" in
        PR_PROVIDERS)         existing_providers="$value" ;;
        OPENROUTER_API_KEY)   existing_openrouter_key="$value" ;;
        GROQ_API_KEY)         existing_groq_key="$value" ;;
        GEMINI_API_KEY)       existing_gemini_key="$value" ;;
        OPENROUTER_MODEL)     existing_openrouter_model="$value" ;;
        GROQ_MODEL)           existing_groq_model="$value" ;;
        GEMINI_MODEL)         existing_gemini_model="$value" ;;
        AZURE_PAT)            existing_azure_pat="$value" ;;
        PR_REVIEWER_DEV)      existing_reviewer_dev="$value" ;;
        PR_REVIEWER_SPRINT)   existing_reviewer_sprint="$value" ;;
      esac
    done < "$ENV_FILE"
  fi

  # Track what needs configuring
  local needs_providers=false
  local needs_openrouter=false
  local needs_groq=false
  local needs_gemini=false
  local needs_pat=false
  local needs_reviewers=false
  local changed=false

  # Detect what's missing
  if [[ -z "$existing_openrouter_key" && -z "$existing_groq_key" && -z "$existing_gemini_key" ]]; then
    needs_providers=true
  fi
  if [[ -z "$existing_openrouter_key" ]]; then needs_openrouter=true; fi
  if [[ -z "$existing_groq_key" ]]; then needs_groq=true; fi
  if [[ -z "$existing_gemini_key" ]]; then needs_gemini=true; fi
  if [[ -z "$existing_azure_pat" ]]; then needs_pat=true; fi
  if [[ -z "$existing_reviewer_dev" || -z "$existing_reviewer_sprint" ]]; then needs_reviewers=true; fi

  # If everything is configured, show summary and ask if they want to change anything
  if [[ "$needs_providers" == "false" && "$needs_pat" == "false" && "$needs_reviewers" == "false" ]]; then
    echo -e "  ${GREEN}Todas as configuracoes ja estao preenchidas:${NC}"
    echo ""
    local masked_or="${existing_openrouter_key:0:4}...${existing_openrouter_key: -4}"
    local masked_groq="${existing_groq_key:0:4}...${existing_groq_key: -4}"
    local masked_gemini="${existing_gemini_key:0:4}...${existing_gemini_key: -4}"
    local masked_pat="${existing_azure_pat:0:4}...${existing_azure_pat: -4}"
    [[ -n "$existing_openrouter_key" ]] && echo -e "    OpenRouter API Key: ${CYAN}${masked_or}${NC}"
    [[ -n "$existing_groq_key" ]] && echo -e "    Groq API Key:       ${CYAN}${masked_groq}${NC}"
    [[ -n "$existing_gemini_key" ]] && echo -e "    Gemini API Key:     ${CYAN}${masked_gemini}${NC}"
    [[ -n "$existing_azure_pat" ]] && echo -e "    Azure PAT:          ${CYAN}${masked_pat}${NC}"
    [[ -n "$existing_reviewer_dev" ]] && echo -e "    Reviewer dev:       ${CYAN}${existing_reviewer_dev}${NC}"
    [[ -n "$existing_reviewer_sprint" ]] && echo -e "    Reviewer sprint:    ${CYAN}${existing_reviewer_sprint}${NC}"
    echo ""
    if ! prompt_yn "Deseja alterar alguma configuracao?" "n"; then
      return
    fi
    # If they want to change, ask everything
    needs_providers=true
    needs_pat=true
    needs_reviewers=true
    echo ""
  fi

  if [[ "$is_update" == "true" ]]; then
    log_info "Configuracao existente detectada. Apenas itens faltantes serao perguntados."
    echo ""
  fi

  # ---- LLM Providers (only if any is missing) ----
  if [[ "$needs_openrouter" == "true" || "$needs_groq" == "true" || "$needs_gemini" == "true" ]]; then
    echo -e "${BOLD}Providers de LLM${NC}"
    echo ""

    # Show what's already configured
    [[ -n "$existing_openrouter_key" ]] && log_success "OpenRouter ja configurado"
    [[ -n "$existing_groq_key" ]] && log_success "Groq ja configurado"
    [[ -n "$existing_gemini_key" ]] && log_success "Google Gemini ja configurado"
    [[ -n "$existing_openrouter_key" || -n "$existing_groq_key" || -n "$existing_gemini_key" ]] && echo ""

    if [[ "$needs_openrouter" == "true" ]]; then
      if prompt_yn "Configurar OpenRouter?" "y"; then
        echo -e "  ${BOLD}OpenRouter${NC} - Crie uma key em: ${CYAN}https://openrouter.ai/keys${NC}"
        local new_or_key
        new_or_key=$(prompt_value "API Key" "" "true")
        if [[ -n "$new_or_key" ]]; then
          echo -en "  Testando key... "
          if test_provider_key "openrouter" "$new_or_key"; then
            echo -e "${GREEN}valida!${NC}"
          else
            echo -e "${RED}falhou${NC}"
            log_warn "A key pode estar errada ou o servico esta fora. Salvando mesmo assim."
          fi
          set_env_var "OPENROUTER_API_KEY" "$new_or_key"
          changed=true
        fi
        echo ""
      fi
    fi

    if [[ "$needs_groq" == "true" ]]; then
      if prompt_yn "Configurar Groq?" "y"; then
        echo -e "  ${BOLD}Groq${NC} - Crie uma key em: ${CYAN}https://console.groq.com/keys${NC}"
        local new_groq_key
        new_groq_key=$(prompt_value "API Key" "" "true")
        if [[ -n "$new_groq_key" ]]; then
          echo -en "  Testando key... "
          if test_provider_key "groq" "$new_groq_key"; then
            echo -e "${GREEN}valida!${NC}"
          else
            echo -e "${RED}falhou${NC}"
            log_warn "A key pode estar errada ou o servico esta fora. Salvando mesmo assim."
          fi
          set_env_var "GROQ_API_KEY" "$new_groq_key"
          changed=true
        fi
        echo ""
      fi
    fi

    if [[ "$needs_gemini" == "true" ]]; then
      if prompt_yn "Configurar Google Gemini?" "y"; then
        echo -e "  ${BOLD}Google Gemini${NC} - Crie uma key em: ${CYAN}https://aistudio.google.com/apikey${NC}"
        local new_gemini_key
        new_gemini_key=$(prompt_value "API Key" "" "true")
        if [[ -n "$new_gemini_key" ]]; then
          echo -en "  Testando key... "
          if test_provider_key "gemini" "$new_gemini_key"; then
            echo -e "${GREEN}valida!${NC}"
          else
            echo -e "${RED}falhou${NC}"
            log_warn "A key pode estar errada ou o servico esta fora. Salvando mesmo assim."
          fi
          set_env_var "GEMINI_API_KEY" "$new_gemini_key"
          changed=true
        fi
        echo ""
      fi
    fi

    # Update providers list if not set
    if [[ -z "$existing_providers" && "$changed" == "true" ]]; then
      set_env_var "PR_PROVIDERS" "openrouter,groq,gemini"
    fi
  else
    log_success "Providers de LLM ja configurados"
  fi

  # ---- Azure DevOps PAT (only if missing) ----
  if [[ "$needs_pat" == "true" ]]; then
    echo -e "${BOLD}Azure DevOps${NC}"
    echo ""
    if prompt_yn "Configurar Azure DevOps PAT?" "y"; then
      echo -e "  Crie um PAT em: ${CYAN}https://dev.azure.com/<sua-org>/_usersSettings/tokens${NC}"
      echo -e "  Permissao necessaria: ${BOLD}Code (Read & Write)${NC}"
      local new_pat
      new_pat=$(prompt_value "PAT Token" "$existing_azure_pat" "true")
      if [[ -n "$new_pat" ]]; then
        echo -en "  Testando PAT... "
        if test_azure_pat "$new_pat"; then
          echo -e "${GREEN}valido!${NC}"
        else
          echo -e "${RED}falhou${NC}"
          log_warn "O PAT pode estar errado ou expirado. Salvando mesmo assim."
        fi
        set_env_var "AZURE_PAT" "$new_pat"
        changed=true
      fi
      echo ""
    fi
  else
    log_success "Azure DevOps PAT ja configurado"
  fi

  # ---- Reviewers (only if missing) ----
  if [[ "$needs_reviewers" == "true" ]]; then
    echo -e "${BOLD}Reviewers${NC}"
    echo -e "  Emails dos reviewers padrao para criacao automatica de PRs."
    echo ""

    if [[ -z "$existing_reviewer_dev" ]]; then
      local new_rev_dev
      new_rev_dev=$(prompt_value "Reviewer para PRs -> dev (email)" "")
      if [[ -n "$new_rev_dev" ]]; then
        set_env_var "PR_REVIEWER_DEV" "$new_rev_dev"
        changed=true
      fi
    else
      echo -e "  Reviewer dev: ${CYAN}${existing_reviewer_dev}${NC}"
      if prompt_yn "Alterar?" "n"; then
        local new_rev_dev
        new_rev_dev=$(prompt_value "Reviewer para PRs -> dev (email)" "$existing_reviewer_dev")
        if [[ -n "$new_rev_dev" ]]; then
          set_env_var "PR_REVIEWER_DEV" "$new_rev_dev"
          changed=true
        fi
      fi
    fi

    if [[ -z "$existing_reviewer_sprint" ]]; then
      local new_rev_sprint
      new_rev_sprint=$(prompt_value "Reviewer para PRs -> sprint (email)" "")
      if [[ -n "$new_rev_sprint" ]]; then
        set_env_var "PR_REVIEWER_SPRINT" "$new_rev_sprint"
        changed=true
      fi
    else
      echo -e "  Reviewer sprint: ${CYAN}${existing_reviewer_sprint}${NC}"
      if prompt_yn "Alterar?" "n"; then
        local new_rev_sprint
        new_rev_sprint=$(prompt_value "Reviewer para PRs -> sprint (email)" "$existing_reviewer_sprint")
        if [[ -n "$new_rev_sprint" ]]; then
          set_env_var "PR_REVIEWER_SPRINT" "$new_rev_sprint"
          changed=true
        fi
      fi
    fi
    echo ""
  else
    log_success "Reviewers ja configurados"
  fi

  if [[ "$changed" == "true" ]]; then
    log_success "Configuracao atualizada em $ENV_FILE"
  else
    log_info "Nenhuma alteracao feita."
  fi
}

do_init() {
  log_info "Inicializando configuracao em $CONFIG_DIR..."

  mkdir -p "$CONFIG_DIR"

  # Create template
  if confirm_overwrite "$TEMPLATE_FILE"; then
    echo "$DEFAULT_TEMPLATE" > "$TEMPLATE_FILE"
    log_success "Template criado: $TEMPLATE_FILE"
  fi

  # Create cache
  if [[ ! -f "$CACHE_FILE" ]]; then
    touch "$CACHE_FILE"
    log_success "Cache criado: $CACHE_FILE"
  fi

  # Ensure .env exists before any wizard or interactive setup
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "$DEFAULT_ENV" > "$ENV_FILE"
    chmod 600 "$ENV_FILE"
    log_success "Arquivo .env criado: $ENV_FILE"
  fi

  # Interactive setup
  if [[ -t 0 ]]; then
    # Interactive terminal: run wizard
    run_setup_wizard
  else
    # Non-interactive (piped): just warn
    log_warn "Edite $ENV_FILE e preencha suas API keys."
  fi

  echo ""
  echo -e "${BOLD}========================================${NC}"
  log_success "Inicializacao concluida!"
  echo -e "${BOLD}========================================${NC}"
}

# ---- Validation ----

validate_git_repo() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    log_error "Não e um repositório git."
    exit 1
  fi
}

validate_not_base_branch() {
  local branch

  if [[ -n "$SOURCE_BRANCH" ]]; then
    branch="$SOURCE_BRANCH"
    # Validate that the source branch exists
    if ! git rev-parse --verify "$branch" &>/dev/null && \
       ! git rev-parse --verify "origin/$branch" &>/dev/null; then
      log_error "Branch '$branch' não encontrada (local ou remota)."
      exit 1
    fi
  else
    branch=$(git branch --show-current 2>/dev/null || echo "")
  fi

  if [[ "$branch" == "dev" || "$branch" == "main" || "$branch" == "master" ]]; then
    log_error "A branch de origem ($branch) e uma branch base. Use uma feature branch."
    exit 1
  fi
  if [[ -z "$branch" ]]; then
    log_error "Não foi possivel determinar a branch atual (detached HEAD?). Use --source para informar a branch."
    exit 1
  fi
}

validate_config() {
  if [[ ! -f "$TEMPLATE_FILE" ]]; then
    log_error "Template não encontrado em $TEMPLATE_FILE"
    log_error "Execute 'create-pr-description --init' para criar."
    exit 1
  fi
}

validate_api_keys() {
  local has_key=false
  if [[ -n "${OPENROUTER_API_KEY:-}" ]]; then has_key=true; fi
  if [[ -n "${GROQ_API_KEY:-}" ]]; then has_key=true; fi
  if [[ -n "${GEMINI_API_KEY:-}" ]]; then has_key=true; fi
  if [[ "$has_key" == "false" ]]; then
    log_error "Nenhuma API key configurada."
    log_error "Execute 'create-pr-description --init' e configure o .env."
    exit 1
  fi
}

# ---- Git Context ----

collect_git_context() {
  if [[ -n "$SOURCE_BRANCH" ]]; then
    # Resolve source branch: prefer local, fallback to remote tracking
    if git rev-parse --verify "$SOURCE_BRANCH" &>/dev/null; then
      BRANCH_NAME="$SOURCE_BRANCH"
    elif git rev-parse --verify "origin/$SOURCE_BRANCH" &>/dev/null; then
      BRANCH_NAME="$SOURCE_BRANCH"
    fi
    log_info "Branch (--source): $BRANCH_NAME"
  else
    BRANCH_NAME=$(git branch --show-current)
    log_info "Branch: $BRANCH_NAME"
  fi

  # Fetch remote (non-fatal on failure)
  if ! git fetch --prune origin 2>/dev/null; then
    log_warn "Falha ao fazer fetch do remote. Usando dados locais."
  fi

  # Determine base branch ref
  # Prefer sprint branch (feature branches are created from sprint, not dev)
  # Fallback order: origin/sprint/N -> origin/dev -> dev -> origin/main -> main
  local base_ref=""

  # Detect sprint branch first for base ref
  local sprint_for_base
  sprint_for_base=$(git branch -r 2>/dev/null \
    | grep 'origin/sprint/' \
    | sed 's|.*origin/sprint/||' \
    | sort -n \
    | tail -1 \
    | tr -d '[:space:]' || echo "")

  if [[ -n "$sprint_for_base" ]] && git rev-parse --verify "origin/sprint/$sprint_for_base" &>/dev/null; then
    base_ref="origin/sprint/$sprint_for_base"
  elif git rev-parse --verify origin/dev &>/dev/null; then
    base_ref="origin/dev"
  elif git rev-parse --verify dev &>/dev/null; then
    base_ref="dev"
  elif git rev-parse --verify origin/main &>/dev/null; then
    base_ref="origin/main"
  elif git rev-parse --verify main &>/dev/null; then
    base_ref="main"
  else
    log_error "Branch base não encontrada."
    exit 1
  fi

  log_info "Base: $base_ref"

  # Resolve source ref: use BRANCH_NAME if --source was provided, otherwise HEAD
  local source_ref="HEAD"
  if [[ -n "$SOURCE_BRANCH" ]]; then
    if git rev-parse --verify "$BRANCH_NAME" &>/dev/null; then
      source_ref="$BRANCH_NAME"
    elif git rev-parse --verify "origin/$BRANCH_NAME" &>/dev/null; then
      source_ref="origin/$BRANCH_NAME"
    fi
  fi

  # Collect diff using temp file (avoids issues with huge diffs in variables)
  local max_diff_lines=8000
  local diff_tmp
  diff_tmp=$(mktemp)
  trap "rm -f '$diff_tmp'" EXIT

  local diff_ok=false

  # Try three-dot diff (changes since common ancestor)
  if git diff "${base_ref}...${source_ref}" > "$diff_tmp" 2>/dev/null; then
    if [[ -s "$diff_tmp" ]]; then
      diff_ok=true
    fi
  fi

  # Fallback: two-dot diff
  if [[ "$diff_ok" == "false" ]]; then
    if git diff "${base_ref}..${source_ref}" > "$diff_tmp" 2>/dev/null; then
      if [[ -s "$diff_tmp" ]]; then
        diff_ok=true
      fi
    fi
  fi

  # Fallback: direct diff
  if [[ "$diff_ok" == "false" ]]; then
    if git diff "${base_ref}" "${source_ref}" > "$diff_tmp" 2>/dev/null; then
      if [[ -s "$diff_tmp" ]]; then
        diff_ok=true
      fi
    fi
  fi

  if [[ "$diff_ok" == "false" ]]; then
    log_error "Nenhuma alteracao encontrada em relacao a ${base_ref}."
    log_error "Verifique se sua branch tem commits diferentes de '${base_ref}'."
    rm -f "$diff_tmp"
    exit 1
  fi

  local diff_lines
  diff_lines=$(wc -l < "$diff_tmp" | tr -d '[:space:]')
  log_info "Diff: $diff_lines linhas"

  if [[ "$diff_lines" -gt "$max_diff_lines" ]]; then
    GIT_DIFF=$(head -n "$max_diff_lines" "$diff_tmp")
    GIT_DIFF="${GIT_DIFF}"$'\n\n[diff truncado, mostrando primeiras '"$max_diff_lines"' linhas de '"$diff_lines"' totais]'
    log_warn "Diff truncado: $diff_lines linhas -> $max_diff_lines linhas"
  else
    GIT_DIFF=$(cat "$diff_tmp")
  fi

  rm -f "$diff_tmp"

  # Collect log
  local git_log_result=""
  if git_log_result=$(git log "${base_ref}...${source_ref}" --oneline --max-count=50 2>/dev/null); then
    GIT_LOG="$git_log_result"
  elif git_log_result=$(git log "${base_ref}..${source_ref}" --oneline --max-count=50 2>/dev/null); then
    GIT_LOG="$git_log_result"
  else
    GIT_LOG="(log não disponivel)"
  fi
}

# ---- Sprint Detection ----

detect_sprint() {
  SPRINT_NUMBER=""
  SPRINT_BRANCH=""

  local sprint_num
  sprint_num=$(git branch -r 2>/dev/null \
    | grep 'origin/sprint/' \
    | sed 's|.*origin/sprint/||' \
    | sort -n \
    | tail -1 \
    | tr -d '[:space:]' || echo "")

  if [[ -n "$sprint_num" ]]; then
    SPRINT_NUMBER="$sprint_num"
    SPRINT_BRANCH="sprint/$sprint_num"
    log_info "Sprint detectada: $SPRINT_BRANCH"
  else
    log_warn "Nenhuma branch sprint encontrada no remote."
    # Remove sprint from targets if it was requested
    local new_targets=()
    local sprint_was_explicit=false

    for t in "${TARGETS[@]}"; do
      if [[ "$t" == "sprint" ]]; then
        sprint_was_explicit=true
      else
        new_targets+=("$t")
      fi
    done

    # If user explicitly asked for --target sprint and no sprint exists, error
    if [[ "$sprint_was_explicit" == "true" && ${#new_targets[@]} -eq 0 ]]; then
      log_error "Flag --target sprint usada, mas nenhuma branch sprint/* encontrada."
      exit 1
    fi

    if [[ ${#new_targets[@]} -gt 0 ]]; then
      TARGETS=("${new_targets[@]}")
    else
      TARGETS=("dev")
    fi
    log_info "Usando apenas targets: ${TARGETS[*]}"
  fi
}

# ---- Work Item ----

detect_work_item() {
  # 1. CLI flag takes priority
  if [[ -n "$CLI_WORK_ITEM" ]]; then
    WORK_ITEM_ID="$CLI_WORK_ITEM"
    log_info "Work item (flag): #$WORK_ITEM_ID"
    return
  fi

  # 2. Try to extract from branch name: tipo/NUMERO-descricao
  if [[ "$BRANCH_NAME" =~ ^[a-zA-Z]+/([0-9]+) ]]; then
    WORK_ITEM_ID="${BASH_REMATCH[1]}"
    log_info "Work item (branch): #$WORK_ITEM_ID"
    return
  fi

  # 3. Interactive prompt (only if terminal is interactive)
  if [[ -t 0 ]]; then
    echo ""
    log_warn "Não foi possivel extrair o work item ID da branch '$BRANCH_NAME'."
    echo -en "  ID do work item (Enter para pular): "
    read -r user_input
    if [[ -n "$user_input" ]]; then
      WORK_ITEM_ID="$user_input"
      log_info "Work item: #$WORK_ITEM_ID"
    else
      log_info "Sem work item vinculado."
    fi
  fi
}

# ---- Clipboard ----

detect_clipboard() {
  if command -v pbcopy &>/dev/null; then
    CLIP_CMD="pbcopy"
  elif command -v wl-copy &>/dev/null; then
    CLIP_CMD="wl-copy"
  elif command -v xclip &>/dev/null; then
    CLIP_CMD="xclip -selection clipboard"
  elif command -v xsel &>/dev/null; then
    CLIP_CMD="xsel --clipboard --input"
  else
    CLIP_CMD=""
  fi
}

copy_to_clipboard() {
  local text="$1"
  if [[ -n "$CLIP_CMD" ]]; then
    echo "$text" | $CLIP_CMD
    return 0
  fi
  return 1
}

# ---- Markdown Rendering ----

detect_md_renderer() {
  if [[ "$RAW_OUTPUT" == "true" ]]; then
    MD_RENDERER_CMD=""
    return
  fi

  if command -v glow &>/dev/null; then
    MD_RENDERER_CMD="glow -"
  elif command -v bat &>/dev/null; then
    MD_RENDERER_CMD="bat --language=md --style=plain --paging=never -"
  elif command -v batcat &>/dev/null; then
    MD_RENDERER_CMD="batcat --language=md --style=plain --paging=never -"
  else
    MD_RENDERER_CMD=""
  fi
}

render_markdown() {
  local content="$1"

  if [[ -n "$MD_RENDERER_CMD" ]]; then
    printf '%s\n' "$content" | $MD_RENDERER_CMD
  else
    echo "$content"
    if [[ "$RAW_OUTPUT" != "true" ]]; then
      log_warn "Nenhum renderizador Markdown encontrado. Instale 'glow' (recomendado) ou 'bat' para uma visualizacao formatada."
    fi
  fi
}

# ---- Output ----

parse_title_and_body() {
  local raw="$1"
  PR_TITLE=""
  PR_BODY=""

  # Strip <think>...</think> blocks (reasoning models like qwen3)
  # Uses sed to remove everything between <think> and </think> tags
  raw=$(printf '%s' "$raw" | sed '/<think>/,/<\/think>/d')
  # Also remove standalone <think> or </think> tags that might remain
  raw=$(printf '%s' "$raw" | sed 's/<think>//g; s/<\/think>//g')
  # Remove leading blank lines after stripping
  raw=$(printf '%s' "$raw" | sed '/./,$!d')

  # Try to find TITULO: line anywhere in the output (case-insensitive match)
  local found_title=false
  local title_line_num=0
  local current_line=0

  while IFS= read -r line; do
    current_line=$((current_line + 1))
    # Match TITULO: or Titulo: or titulo: with optional leading whitespace
    if [[ "$found_title" == "false" && "$line" =~ ^[[:space:]]*[Tt][Ii][Tt][Uu][Ll][Oo]:[[:space:]]*(.+) ]]; then
      PR_TITLE="${BASH_REMATCH[1]}"
      found_title=true
      title_line_num=$current_line
      break
    fi
  done <<< "$raw"

  if [[ "$found_title" == "true" && -n "$PR_TITLE" ]]; then
    # Collect only lines AFTER the TITULO: line as the body
    local body_lines=""
    local line_count=0
    while IFS= read -r line; do
      line_count=$((line_count + 1))
      if [[ $line_count -gt $title_line_num ]]; then
        body_lines="${body_lines}${line}"$'\n'
      fi
    done <<< "$raw"
    PR_BODY="$body_lines"
  else
    # Fallback: extract title from ## Descrição section's first sentence
    local desc_line
    desc_line=$(printf '%s' "$raw" | grep -A1 "^## Descrição" | tail -1 | sed 's/^[[:space:]]*//' || true)
    if [[ -n "$desc_line" && "$desc_line" != "##"* ]]; then
      # Truncate to 80 chars
      PR_TITLE="${desc_line:0:80}"
    else
      # Last resort: use branch name
      PR_TITLE="$BRANCH_NAME"
    fi
    PR_BODY="$raw"
  fi

  # Clean up title: remove quotes, trailing dots, leading/trailing whitespace
  PR_TITLE=$(printf '%s' "$PR_TITLE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^"//;s/"$//')

  # Clean up body: remove leading blank lines and standalone ---
  PR_BODY=$(printf '%s\n' "$PR_BODY" | sed '/./,$!d')
  # Remove leading --- if first non-empty line
  if [[ "$(printf '%s\n' "$PR_BODY" | head -1)" == "---" ]]; then
    PR_BODY=$(printf '%s\n' "$PR_BODY" | tail -n +2 | sed '/./,$!d')
  fi
}

print_output() {
  local raw_result="$1"
  local separator="=========================================="

  # Parse title and body
  parse_title_and_body "$raw_result"

  echo ""
  echo -e "${BOLD}${separator}${NC}"
  echo -e "${BOLD}PR - ${CYAN}${BRANCH_NAME}${NC}"

  # Show target branches
  local target_display=""
  for target in "${TARGETS[@]}"; do
    if [[ "$target" == "dev" ]]; then
      target_display="${target_display}dev, "
    elif [[ "$target" == "sprint" && -n "$SPRINT_BRANCH" ]]; then
      target_display="${target_display}${SPRINT_BRANCH}, "
    fi
  done
  target_display="${target_display%, }"
  echo -e "${BOLD}Target branches: ${target_display}${NC}"
  echo -e "${BOLD}Provider: ${USED_PROVIDER} (${USED_MODEL})${NC}"
  if [[ -n "$WORK_ITEM_ID" ]]; then
    echo -e "${BOLD}Work Item: ${CYAN}#${WORK_ITEM_ID}${NC}"
  fi
  echo -e "${BOLD}${separator}${NC}"

  # Title
  echo ""
  echo -e "${BOLD}Titulo:${NC} ${CYAN}${PR_TITLE}${NC}"
  echo ""

  # Body
  echo -e "${BOLD}Descrição:${NC}"
  render_markdown "$PR_BODY"
  echo ""

  # PR Links and Work Item link
  if [[ ${#PR_LINKS[@]} -gt 0 || -n "$WORK_ITEM_ID" ]]; then
    echo -e "${BOLD}${separator}${NC}"

    if [[ -n "$WORK_ITEM_ID" && "$IS_AZURE_DEVOPS" == "true" ]]; then
      echo -e "${BOLD}Work Item:${NC}"
      echo -e "  -> ${CYAN}#${WORK_ITEM_ID}${NC}:"
      echo -e "     https://dev.azure.com/$AZURE_ORG/$AZURE_PROJECT/_workitems/edit/$WORK_ITEM_ID"
      echo ""
    fi

    if [[ ${#PR_LINKS[@]} -gt 0 ]]; then
      echo -e "${BOLD}Abrir PR:${NC}"
      echo ""
      for link_entry in "${PR_LINKS[@]}"; do
        local target_ref="${link_entry%%|*}"
        local url="${link_entry#*|}"
        echo -e "  -> ${CYAN}${target_ref}${NC}:"
        echo -e "     ${url}"
        echo ""
      done
    fi
  fi

  # Clipboard - copy body (description)
  detect_clipboard
  if copy_to_clipboard "$PR_BODY"; then
    echo -e "${BOLD}Descrição copiada para o clipboard!${NC}"
    echo -e "  Titulo disponivel acima para copiar manualmente."
  else
    log_warn "Nenhum comando de clipboard encontrado (pbcopy/xclip/xsel). Descrição exibida apenas no terminal."
  fi
  echo -e "${BOLD}${separator}${NC}"
}

# ---- Main ----

main() {
  parse_args "$@"

  if [[ "$ACTION" == "init" ]]; then
    do_init
    exit 0
  fi

  # Validation
  ui_title_start "Gerando descricao do PR..."
  step_start "Validando dependencias"
  validate_dependencies
  validate_git_repo
  step_done "Dependencias validadas"

  step_start "Carregando configuracao"
  load_config
  validate_config
  step_done "Configuracao carregada"

  step_start "Validando API keys"
  validate_api_keys
  step_done "API keys validadas"

  step_start "Validando branch"
  validate_not_base_branch
  step_done "Branch validada"

  # Collect context
  step_start "Coletando contexto git"
  collect_git_context
  step_done "Contexto git coletado ($BRANCH_NAME)"

  step_start "Detectando work item"
  detect_work_item
  if [[ -n "$WORK_ITEM_ID" ]]; then
    step_done "Work item: #$WORK_ITEM_ID"
  else
    step_done "Sem work item detectado"
  fi

  step_start "Detectando sprint"
  detect_sprint
  if [[ -n "$SPRINT_NUMBER" ]]; then
    step_done "Sprint: $SPRINT_NUMBER"
  else
    step_done "Sem sprint ativo"
  fi

  step_start "Resolvendo repositório Azure DevOps"
  parse_azure_remote
  fetch_repo_id
  build_pr_links
  if [[ "$IS_AZURE_DEVOPS" == "true" ]]; then
    step_done "Repositório: $AZURE_ORG/$AZURE_PROJECT/$AZURE_REPO"
  else
    step_done "Repositório não-Azure (sem links de PR)"
  fi

  detect_md_renderer

  # Read template
  local template_content
  template_content=$(cat "$TEMPLATE_FILE")

  # Build user prompt
  local target_display=""
  for target in "${TARGETS[@]}"; do
    if [[ "$target" == "dev" ]]; then
      target_display="${target_display}dev, "
    elif [[ "$target" == "sprint" && -n "$SPRINT_BRANCH" ]]; then
      target_display="${target_display}${SPRINT_BRANCH}, "
    fi
  done
  target_display="${target_display%, }"

  # Work item context
  local work_item_context=""
  if [[ -n "$WORK_ITEM_ID" ]]; then
    work_item_context="
**Work Item:** #$WORK_ITEM_ID"
  fi

  local user_prompt
  user_prompt="## Contexto Git

**Branch:** $BRANCH_NAME
**Base branches alvo:** $target_display${work_item_context}

### Git Log (commits desde a base):
$GIT_LOG

### Git Diff:
$GIT_DIFF"

  # Dry-run: show prompt and exit
  if [[ "$DRY_RUN" == "true" ]]; then
    local separator="=========================================="
    echo ""
    echo -e "${BOLD}${separator}${NC}"
    echo -e "${BOLD}DRY RUN - Prompt que seria enviado ao LLM${NC}"
    echo -e "${BOLD}${separator}${NC}"
    echo ""
    echo -e "${BOLD}[SYSTEM]${NC}"
    echo "$template_content"
    echo ""
    echo -e "${BOLD}[USER]${NC}"
    echo "$user_prompt"
    echo ""
    echo -e "${BOLD}${separator}${NC}"
    echo -e "Provider: ${PR_PROVIDERS%,*} | Modelo: ${OPENROUTER_MODEL:-$DEFAULT_OPENROUTER_MODEL}"
    echo -e "${BOLD}${separator}${NC}"
    exit 0
  fi

  # Call LLM
  step_start "Gerando descrição via LLM"
  if [[ "$STREAM_MODE" == "true" ]]; then
    _spinner_stop
    _spinner_clear_line
    echo "" >&2
    echo -e "${DIM}--- Streaming resposta do LLM ---${NC}" >&2
    echo "" >&2
  fi
  call_with_fallback "$template_content" "$user_prompt"
  if [[ "$STREAM_MODE" == "true" ]]; then
    echo "" >&2
    echo -e "${DIM}--- Resposta completa recebida ---${NC}" >&2
  fi
  step_done "Descrição gerada ($USED_PROVIDER/$USED_MODEL)"
  ui_title_done

  # Output
  print_output "$LLM_RESULT"

  # Offer PR creation
  offer_pr_creation
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi

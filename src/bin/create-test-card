#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# create-test-card
# Generates Azure DevOps test cards using LLM providers
# from PR + Work Item context, with best-effort creation.
# ============================================================

VERSION="0.3.2"
CONFIG_DIR="$HOME/.config/pr-tools"
ENV_FILE="$CONFIG_DIR/.env"
CACHE_FILE="$CONFIG_DIR/.cache"
REPO_URL="https://raw.githubusercontent.com/nitoba/pr-tools/main"

DEFAULT_PROVIDERS="openrouter,groq,gemini"
DEFAULT_OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
DEFAULT_GROQ_MODEL="llama-3.3-70b-versatile"
DEFAULT_GEMINI_MODEL="gemini-3.1-flash-lite-preview"
DEFAULT_AGROTRACE_AREA_PATH="AGROTRACE\\Devops"
DEFAULT_AGROTRACE_PRIORITY="2"
DEFAULT_AGROTRACE_TEAM="DevOps"
DEFAULT_AGROTRACE_PROGRAMA="Agrotrace"
DEFAULT_EXAMPLES=2
MAX_EXAMPLES=5
MAX_CHANGED_FILES=200
MAX_DIFF_LINES=300
MAX_DIFF_CHARS=8000

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

if [[ ! -t 1 || -n "${NO_COLOR:-}" ]]; then
  RED=''
  YELLOW=''
  GREEN=''
  CYAN=''
  BOLD=''
  DIM=''
  NC=''
fi

# ---- Source shared libs ----
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib/pr-tools"
if [[ ! -d "$LIB_DIR" ]]; then
  LIB_DIR="${SCRIPT_DIR}/../lib"
fi

# Auto-download libs if missing (handles upgrade from monolithic version)
for _required_lib in common.sh test-card-azure.sh test-card-llm.sh ui.sh; do
  if [[ ! -f "$LIB_DIR/$_required_lib" ]]; then
    echo "[INFO] Bibliotecas não encontradas. Baixando automaticamente..." >&2
    mkdir -p "$LIB_DIR"
    for _lib in common.sh llm.sh azure.sh test-card-azure.sh test-card-llm.sh ui.sh; do
      if ! curl -fsSL "$REPO_URL/src/lib/$_lib" -o "$LIB_DIR/$_lib" 2>/dev/null; then
        echo "[ERRO] Falha ao baixar $LIB_DIR/$_lib" >&2
        echo "[ERRO] Execute: curl -fsSL $REPO_URL/install.sh | bash" >&2
        exit 1
      fi
    done
    echo "[OK] Bibliotecas instaladas em $LIB_DIR" >&2
    break
  fi
done

source "$LIB_DIR/common.sh"
source "$LIB_DIR/test-card-azure.sh"
source "$LIB_DIR/test-card-llm.sh"
source "$LIB_DIR/ui.sh"

ACTION=""
DRY_RUN=false
RAW_OUTPUT=false
NO_CREATE=false
DEBUG_MODE=false

IN_GIT_REPO=false
BRANCH_NAME=""
SOURCE_REF_NAME=""
IS_AZURE_DEVOPS=false

CLI_PR_ID=""
CLI_WORK_ITEM_ID=""
CLI_ORG=""
CLI_PROJECT=""
CLI_REPO=""
CLI_AREA_PATH=""
CLI_ASSIGNED_TO=""
EXAMPLE_COUNT="$DEFAULT_EXAMPLES"

AZURE_ORG=""
AZURE_PROJECT=""
AZURE_REPO=""
AZURE_REPO_ID=""
AZURE_ORG_ENC=""
AZURE_PROJECT_ENC=""
AZURE_REPO_ENC=""

PR_ID=""
WORK_ITEM_ID=""
WORK_ITEM_TYPE=""
WORK_ITEM_TITLE=""
WORK_ITEM_DESCRIPTION=""
WORK_ITEM_AREA_PATH=""
WORK_ITEM_ITERATION_PATH=""
WORK_ITEM_PRIORITY=""

PR_TITLE=""
PR_DESCRIPTION=""
PR_STATUS=""
PR_SOURCE_REF=""
PR_TARGET_REF=""
PR_REPOSITORY_NAME=""

SELECTED_AREA_PATH=""
SELECTED_ASSIGNED_TO=""
ATTEMPTED_PRIORITY=""
ATTEMPTED_TEAM=""
ATTEMPTED_PROGRAMA=""

CHANGED_FILES_SUMMARY=""
DIFF_SUMMARY=""
EXAMPLES_SUMMARY=""
LINKED_WORK_ITEMS_SUMMARY=""

GENERATED_TITLE=""
GENERATED_MARKDOWN=""
GENERATED_HTML=""
GENERATED_STEPS=""
LLM_RESULT=""
USED_PROVIDER=""
USED_MODEL=""
CREATE_ERROR=""
CREATED_TEST_CASE_ID=""
CREATED_TEST_CASE_URL=""
UPDATED_PARENT_TO_TEST_QA=false

DEFAULT_SYSTEM_PROMPT='Voce é um analista de QA tecnico.

Sua tarefa é gerar um card de teste em portugues brasileiro para Azure DevOps com base em:
1. Work item pai
2. Pull request relacionado
3. Arquivos alterados e resumo tecnico do PR
4. Exemplos de test cases existentes

IMPORTANTE: A PRIMEIRA LINHA da sua resposta DEVE ser exatamente:
TITULO: <titulo curto e objetivo>

Depois disso, responda em Markdown com estas secoes nesta ordem:

## Objetivo
## Cenario base
## Checklist de testes
## Resultado esperado

Regras:
- Escreva em portugues brasileiro
- Não invente comportamento que não esteja sustentado pelo contexto
- Foque em cobertura funcional, validacoes e regressao quando fizer sentido
- Seja especifico e tecnico, sem ser prolixo
- O titulo deve ser curto e claro
- O checklist deve ser acionavel para QA
- Se houver limites, formatos aceitos, obrigatoriedade, bloqueios ou reaproveitamento de comportamento, inclua isso quando sustentado pelo contexto
- Não mencione detalhes tecnicos de implementacao na resposta final
- Não cite nomes de arquivos, componentes, classes, funcoes, migrations, APIs internas, queries ou trechos de codigo
- Não descreva a solucao como tarefa de desenvolvimento; descreva apenas cenarios observaveis e validaveis por QA
- Transforme pistas tecnicas em comportamento funcional testavel pelo usuario final ou pelo analista de QA'

DEFAULT_ENV='# Providers em ordem de prioridade
PR_PROVIDERS="openrouter,groq,gemini"

# API Keys
# OPENROUTER_API_KEY="sk-or-..."
# GROQ_API_KEY="gsk_..."
# GEMINI_API_KEY="..."

# Modelos (opcional)
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# GROQ_MODEL="llama-3.3-70b-versatile"
# GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# Azure DevOps
# AZURE_PAT="your-pat-token"

# Test cards
# TEST_CARD_AREA_PATH="AGROTRACE\\Devops"
# TEST_CARD_ASSIGNED_TO="nome@empresa.com"'

show_help() {
  cat <<'HELP'
create-test-card [opcoes]

Gera um card de teste para Azure DevOps a partir de PR e Work Item,
com autodeteccao inteligente a partir da branch atual quando possivel.

Opcoes:
  --work-item <id>      ID do work item pai (override)
  --pr <id>             ID do PR do Azure DevOps (override)
  --org <nome>          Organization do Azure DevOps (override)
  --project <nome>      Projeto do Azure DevOps (override)
  --repo <nome>         Repositório do Azure DevOps (override)
  --area-path <path>    AreaPath para criacao do Test Case (override)
  --assigned-to <valor> Responsavel do Test Case (override)
  --examples <n>        Quantidade de exemplos no prompt (0-5, padrao: 2)
  --no-create           Gera o card mas não tenta criar o Test Case
  --dry-run             Mostra prompts e preview da criacao sem chamar LLM nem criar
  --raw                 Imprime somente o Markdown no stdout
  --debug               Exibe detalhes de diagnostico
  --init                Inicializa/atualiza a configuracao local
  --update              Atualiza o script para a versao mais recente
  --help                Mostra esta ajuda
  --version             Mostra a versao

Exemplos:
  create-test-card
  create-test-card --pr 10513
  create-test-card --work-item 11796 --pr 10513
  create-test-card --no-create
  create-test-card --dry-run --debug
HELP
}

do_init() {
  mkdir -p "$CONFIG_DIR"
  touch "$CACHE_FILE"

  if [[ ! -f "$ENV_FILE" ]]; then
    printf '%s\n' "$DEFAULT_ENV" > "$ENV_FILE"
    chmod 600 "$ENV_FILE"
    log_success "Arquivo .env criado: $ENV_FILE"
  else
    ensure_env_key_comment "TEST_CARD_AREA_PATH" "$DEFAULT_AGROTRACE_AREA_PATH"
    ensure_env_key_comment "TEST_CARD_ASSIGNED_TO" "nome@empresa.com"
    log_success "Arquivo .env atualizado: $ENV_FILE"
  fi

  if [[ -t 0 ]]; then
    echo ""
    echo -e "${BOLD}Configuracao do create-test-card${NC}"
    echo ""

    if [[ -z "${TEST_CARD_AREA_PATH:-}" ]]; then
      local new_area
      new_area=$(prompt_value "AreaPath padrao para Test Case" "$DEFAULT_AGROTRACE_AREA_PATH")
      if [[ -n "$new_area" ]]; then
        set_env_var "TEST_CARD_AREA_PATH" "$new_area"
      fi
    fi

    if [[ -z "${TEST_CARD_ASSIGNED_TO:-}" ]]; then
      local new_assignee
      new_assignee=$(prompt_value "Responsavel padrao do Test Case" "")
      if [[ -n "$new_assignee" ]]; then
        set_env_var "TEST_CARD_ASSIGNED_TO" "$new_assignee"
      fi
    fi

    if [[ -z "${AZURE_PAT:-}" ]]; then
      if prompt_yn "Configurar Azure DevOps PAT agora?" "y"; then
        local new_pat
        new_pat=$(prompt_value "PAT Token" "" "true")
        if [[ -n "$new_pat" ]]; then
          echo -en "  Testando PAT... "
          if test_azure_pat "$new_pat"; then
            echo -e "${GREEN}valido!${NC}"
          else
            echo -e "${RED}falhou${NC}"
            log_warn "O PAT pode estar errado ou expirado. Salvando mesmo assim."
          fi
          set_env_var "AZURE_PAT" "$new_pat"
        fi
      fi
    fi
  fi

  log_success "Inicializacao concluida."
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --work-item)
        [[ -n "${2:-}" ]] || { log_error "Flag --work-item requer um ID."; exit 1; }
        [[ "$2" =~ ^[0-9]+$ && "$2" != "0" ]] || { log_error "--work-item deve ser um inteiro positivo."; exit 1; }
        CLI_WORK_ITEM_ID="$2"
        shift 2
        ;;
      --pr)
        [[ -n "${2:-}" ]] || { log_error "Flag --pr requer um ID."; exit 1; }
        [[ "$2" =~ ^[0-9]+$ && "$2" != "0" ]] || { log_error "--pr deve ser um inteiro positivo."; exit 1; }
        CLI_PR_ID="$2"
        shift 2
        ;;
      --org)
        [[ -n "${2:-}" ]] || { log_error "Flag --org requer um valor."; exit 1; }
        CLI_ORG="$2"
        shift 2
        ;;
      --project)
        [[ -n "${2:-}" ]] || { log_error "Flag --project requer um valor."; exit 1; }
        CLI_PROJECT="$2"
        shift 2
        ;;
      --repo)
        [[ -n "${2:-}" ]] || { log_error "Flag --repo requer um valor."; exit 1; }
        CLI_REPO="$2"
        shift 2
        ;;
      --area-path)
        [[ -n "${2:-}" ]] || { log_error "Flag --area-path requer um valor."; exit 1; }
        CLI_AREA_PATH="$2"
        shift 2
        ;;
      --assigned-to)
        [[ -n "${2:-}" ]] || { log_error "Flag --assigned-to requer um valor."; exit 1; }
        CLI_ASSIGNED_TO="$2"
        shift 2
        ;;
      --examples)
        [[ -n "${2:-}" ]] || { log_error "Flag --examples requer um valor."; exit 1; }
        [[ "$2" =~ ^[0-9]+$ ]] || { log_error "--examples deve ser um inteiro."; exit 1; }
        if (( 10#$2 < 0 || 10#$2 > MAX_EXAMPLES )); then
          log_error "--examples deve estar entre 0 e $MAX_EXAMPLES."
          exit 1
        fi
        EXAMPLE_COUNT="$2"
        shift 2
        ;;
      --no-create)
        NO_CREATE=true
        shift
        ;;
      --dry-run)
        DRY_RUN=true
        NO_CREATE=true
        shift
        ;;
      --raw)
        RAW_OUTPUT=true
        shift
        ;;
      --debug)
        DEBUG_MODE=true
        shift
        ;;
      --init)
        ACTION="init"
        shift
        ;;
      --update)
        do_update "create-test-card" "$VERSION" "$REPO_URL"
        exit 0
        ;;
      --help)
        show_help
        exit 0
        ;;
      --version)
        echo "create-test-card v$VERSION"
        exit 0
        ;;
      *)
        log_error "Opção desconhecida: $1"
        show_help
        exit 1
        ;;
    esac
  done
}

validate_provider_keys() {
  if [[ "$DRY_RUN" == "true" ]]; then
    return
  fi
  if [[ -z "${OPENROUTER_API_KEY:-}" && -z "${GROQ_API_KEY:-}" && -z "${GEMINI_API_KEY:-}" ]]; then
    log_error "Nenhuma API key configurada. Execute 'create-test-card --init' ou ajuste $ENV_FILE."
    exit 1
  fi
}

validate_azure_pat() {
  if [[ -z "${AZURE_PAT:-}" ]]; then
    log_error "AZURE_PAT não configurado. Execute 'create-test-card --init' ou ajuste $ENV_FILE."
    exit 1
  fi
}

detect_git_context() {
  if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null; then
    IN_GIT_REPO=true
    BRANCH_NAME=$(git branch --show-current 2>/dev/null || echo "")
    if [[ -n "$BRANCH_NAME" ]]; then
      SOURCE_REF_NAME="refs/heads/$BRANCH_NAME"
    fi
  fi
}

print_create_field_summary() {
  cat <<EOF
Campos tentados na criacao:
- AreaPath: $SELECTED_AREA_PATH
- IterationPath: ${WORK_ITEM_ITERATION_PATH:-<empty>}
- Priority: ${ATTEMPTED_PRIORITY:-<empty>}
- Custom.Team: ${ATTEMPTED_TEAM:-<empty>}
- Custom.ProgramasAgrotrace: ${ATTEMPTED_PROGRAMA:-<empty>}
- AssignedTo: ${SELECTED_ASSIGNED_TO:-<empty>}
- Parent: #$WORK_ITEM_ID
EOF
}

print_dry_run() {
  local user_prompt="$1"
  echo ""
  echo -e "${BOLD}[SYSTEM]${NC}"
  printf '%s\n' "$DEFAULT_SYSTEM_PROMPT"
  echo ""
  echo -e "${BOLD}[USER]${NC}"
  printf '%s\n' "$user_prompt"
  echo ""
  echo -e "${BOLD}[CREATE PREVIEW]${NC}"
  cat <<EOF
type: Test Case
title: <from LLM response>
areaPath: $SELECTED_AREA_PATH
assignedTo: ${SELECTED_ASSIGNED_TO:-<not configured>}
parentId: $WORK_ITEM_ID
iterationPath: ${WORK_ITEM_ITERATION_PATH:-<empty>}
priority: ${ATTEMPTED_PRIORITY:-<empty>}
customTeam: ${ATTEMPTED_TEAM:-<empty>}
customProgramasAgrotrace: ${ATTEMPTED_PROGRAMA:-<empty>}
descriptionHtml: <from LLM response converted to HTML>
EOF
}

print_output() {
  if [[ "$RAW_OUTPUT" == "true" ]]; then
    printf '%s\n' "$GENERATED_MARKDOWN"
    return
  fi

  echo ""
  echo -e "${BOLD}========================================${NC}"
  echo -e "${BOLD}Test Card - PR #$PR_ID${NC}"
  echo -e "${BOLD}========================================${NC}"
  echo -e "Provider: ${CYAN}${USED_PROVIDER:-n/a}${NC} (${USED_MODEL:-n/a})"
  echo -e "Work Item pai: ${CYAN}#$WORK_ITEM_ID${NC} - $WORK_ITEM_TITLE"
  echo -e "AreaPath Teste: ${CYAN}$SELECTED_AREA_PATH${NC}"
  if [[ -n "$SELECTED_ASSIGNED_TO" ]]; then
    echo -e "Responsavel: ${CYAN}$SELECTED_ASSIGNED_TO${NC}"
  fi
  echo ""
  echo -e "${BOLD}Titulo:${NC} $GENERATED_TITLE"
  echo ""
  printf '%s\n' "$GENERATED_MARKDOWN"
}

print_create_result() {
  if [[ "$RAW_OUTPUT" == "true" ]]; then
    if [[ -n "$CREATED_TEST_CASE_ID" ]]; then
      echo "Test Case criado: #$CREATED_TEST_CASE_ID $CREATED_TEST_CASE_URL" >&2
    elif [[ -n "$CREATE_ERROR" ]]; then
      echo "Falha ao criar Test Case: $CREATE_ERROR" >&2
      print_create_field_summary >&2
    fi
    return
  fi

  echo ""
  if [[ -n "$CREATED_TEST_CASE_ID" ]]; then
    log_success "Test Case criado com sucesso: #$CREATED_TEST_CASE_ID"
    echo "$CREATED_TEST_CASE_URL"
  elif [[ -n "$CREATE_ERROR" ]]; then
    log_warn "Não foi possivel criar o Test Case automaticamente."
    echo "$CREATE_ERROR"
    print_create_field_summary
    echo "Use o Markdown gerado acima para criar o card manualmente no Azure DevOps; isso costuma acontecer quando o processo exige campos customizados obrigatorios."
  fi
}

confirm_test_case_creation() {
  if [[ "$NO_CREATE" == "true" ]]; then
    return 1
  fi

  if [[ ! -t 0 || ! -t 1 ]]; then
    log_warn "Ambiente não interativo; pulando criacao automatica do Test Case. Rode interativamente para confirmar a criacao."
    return 1
  fi

  echo ""
  if ! prompt_yn "Criar este Test Case no Azure DevOps?" "n"; then
    log_info "Criacao do Test Case cancelada pelo usuario."
    return 1
  fi

  return 0
}

confirm_parent_test_qa_update() {
  if [[ -z "$CREATED_TEST_CASE_ID" ]]; then
    return 1
  fi

  if [[ ! -t 0 || ! -t 1 ]]; then
    return 1
  fi

  echo ""
  if ! prompt_yn "Atualizar o work item #$WORK_ITEM_ID para Test QA?" "n"; then
    log_info "Atualizacao do work item pai cancelada pelo usuario."
    return 1
  fi

  return 0
}

main() {
  parse_args "$@"

  if [[ "$ACTION" == "init" ]]; then
    load_config
    do_init
    exit 0
  fi

  ui_title_start "Gerando card de teste..."
  step_start "Validando dependencias"
  validate_dependencies
  step_done "Dependencias validadas"

  step_start "Carregando configuracao"
  load_config
  step_done "Configuracao carregada"

  step_start "Validando Azure PAT"
  validate_azure_pat
  step_done "Azure PAT validado"

  step_start "Validando API keys"
  validate_provider_keys
  step_done "API keys validadas"

  step_start "Detectando contexto git"
  detect_git_context
  parse_azure_remote
  step_done "Contexto git detectado"

  step_start "Resolvendo contexto Azure DevOps"
  resolve_routing
  step_done "Azure DevOps: $AZURE_ORG/$AZURE_PROJECT"

  step_start "Resolvendo PR"
  resolve_pr
  step_done "PR: #$PR_ID — $PR_TITLE"

  step_start "Resolvendo work item"
  resolve_work_item
  step_done "Work item: #$WORK_ITEM_ID — $WORK_ITEM_TITLE"

  step_start "Buscando alteracoes do PR"
  fetch_pr_changes
  step_done "Alteracoes coletadas"

  step_start "Buscando exemplos de test case"
  fetch_example_test_cases
  step_done "Exemplos coletados"

  step_start "Preparando campos de criacao"
  resolve_creation_defaults
  step_done "Campos resolvidos"

  local user_prompt
  user_prompt=$(build_user_prompt)

  # Dry-run: keep EXACTLY as current code
  if [[ "$DRY_RUN" == "true" ]]; then
    if [[ "$RAW_OUTPUT" == "true" ]]; then
      printf '%s\n\n%s\n\n' "$DEFAULT_SYSTEM_PROMPT" "$user_prompt"
      cat <<EOF
type: Test Case
title: <from LLM response>
areaPath: $SELECTED_AREA_PATH
assignedTo: ${SELECTED_ASSIGNED_TO:-<not configured>}
parentId: $WORK_ITEM_ID
iterationPath: ${WORK_ITEM_ITERATION_PATH:-<empty>}
priority: ${ATTEMPTED_PRIORITY:-<empty>}
customTeam: ${ATTEMPTED_TEAM:-<empty>}
customProgramasAgrotrace: ${ATTEMPTED_PROGRAMA:-<empty>}
descriptionHtml: <from LLM response converted to HTML>
EOF
      exit 0
    fi
    print_dry_run "$user_prompt"
    exit 0
  fi

  step_start "Gerando card via LLM"
  call_with_fallback "$user_prompt"
  LLM_RESULT=$(strip_think_blocks "$LLM_RESULT")
  parse_llm_result
  GENERATED_HTML=$(markdown_to_html "$GENERATED_MARKDOWN")
  GENERATED_STEPS=$(markdown_to_azure_steps "$GENERATED_MARKDOWN")
  step_done "Card gerado ($USED_PROVIDER/$USED_MODEL)"
  ui_title_done

  print_output

  if confirm_test_case_creation; then
    step_start "Criando test case no Azure DevOps"
    if create_test_case; then
      step_done "Test case criado: #$CREATED_TEST_CASE_ID"
    else
      step_fail "Falha ao criar test case"
    fi
  fi

  print_create_result

  if confirm_parent_test_qa_update; then
    step_start "Atualizando work item para Test QA"
    if update_parent_work_item_to_test_qa; then
      step_done "Work item #$WORK_ITEM_ID atualizado para Test QA"
    else
      step_fail "Falha ao atualizar work item"
    fi
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi

---
declare const __APP_VERSION__: string;
const version = __APP_VERSION__;

const links = [
  { label: "Documentação", href: "/docs" },
  {
    label: "GitHub",
    href: "https://github.com/nitoba/pr-tools",
    external: true,
  },
  {
    label: "Releases",
    href: "https://github.com/nitoba/pr-tools/releases",
    external: true,
  },
];
---

<footer class="border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-10">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <div class="max-w-xs">
        <p class="mb-2 text-sm font-semibold text-foreground">pr-tools</p>
        <p class="text-sm leading-relaxed text-muted-foreground">
          AI-powered PR tools para devs no Azure DevOps.
        </p>
      </div>

      <div class="flex flex-col gap-3">
        <p
          class="text-xs font-semibold uppercase tracking-wider text-muted-foreground"
        >
          Links
        </p>
        {
          links.map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener" : undefined}
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div
      class="mt-10 flex items-center justify-between border-t border-border pt-6"
    >
      <p class="font-mono text-xs text-muted-foreground">
        © 2026 pr-tools · MIT License
      </p>
      <p class="font-mono text-xs text-primary">{version}</p>
    </div>
  </div>
</footer>

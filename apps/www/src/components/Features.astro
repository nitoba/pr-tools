---
const features = [
  {
    title: "prt desc — PR Description",
    description:
      "Analisa o git diff (até 8000 linhas) e gera descrições ricas com contexto do Azure DevOps Work Item. Fallback automático entre providers com progresso ao vivo no terminal.",
    icon: "bolt",
  },
  {
    title: "prt test — Test Cards",
    description:
      "Gera cards de teste no Azure DevOps a partir do PR e Work Item. Estrutura BDD com cenários, steps e critérios de aceite — prontos para QA.",
    icon: "beaker",
  },
  {
    title: "Multi-provider AI",
    description:
      "OpenRouter, Groq, Gemini e Ollama. Fallback automático entre providers. Troca de modelo com prt desc --set-groq-model ou via variável de ambiente.",
    icon: "cpu",
  },
];
---

<section class="fade-in-up mx-auto max-w-7xl px-6 py-24 lg:px-10 lg:py-32">
  <div class="mb-14">
    <p
      class="mb-3 font-mono text-[0.7rem] font-medium uppercase tracking-[0.2em] text-primary"
    >
      Funcionalidades
    </p>
    <h2
      class="max-w-lg text-3xl font-bold tracking-[-0.03em] text-foreground md:text-4xl"
    >
      Tudo que você precisa,<br />nada que você não precisa.
    </h2>
  </div>

  <!-- Bento grid: first card spans full width, two below side by side -->
  <div class="grid gap-px overflow-hidden rounded-lg border border-border bg-border md:grid-cols-2">
    <!-- Featured card — spans full width -->
    <div class="fade-in-up group bg-card p-8 transition-colors duration-200 hover:bg-card/80 md:col-span-2">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:gap-10">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-primary/10">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div class="max-w-lg">
          <h3 class="mb-2 text-base font-semibold text-foreground">
            {features[0].title}
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {features[0].description}
          </p>
        </div>
      </div>
    </div>

    <!-- Second card -->
    <div class="fade-in-up stagger-1 group bg-card p-8 transition-colors duration-200 hover:bg-card/80">
      <div class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
          <path d="M4.5 3h15"/>
          <path d="M6 3v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V3"/>
          <path d="M6 14h12"/>
        </svg>
      </div>
      <h3 class="mb-2 mt-5 text-base font-semibold text-foreground">
        {features[1].title}
      </h3>
      <p class="text-sm leading-relaxed text-muted-foreground">
        {features[1].description}
      </p>
    </div>

    <!-- Third card -->
    <div class="fade-in-up stagger-2 group bg-card p-8 transition-colors duration-200 hover:bg-card/80">
      <div class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
          <rect width="16" height="16" x="4" y="4" rx="2"/>
          <rect width="6" height="6" x="9" y="9" rx="1"/>
          <path d="M15 2v2"/>
          <path d="M15 20v2"/>
          <path d="M2 15h2"/>
          <path d="M2 9h2"/>
          <path d="M20 15h2"/>
          <path d="M20 9h2"/>
          <path d="M9 2v2"/>
          <path d="M9 20v2"/>
        </svg>
      </div>
      <h3 class="mb-2 mt-5 text-base font-semibold text-foreground">
        {features[2].title}
      </h3>
      <p class="text-sm leading-relaxed text-muted-foreground">
        {features[2].description}
      </p>
    </div>
  </div>
</section>

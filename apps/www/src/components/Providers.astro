---
const providers = ["OpenRouter", "Groq", "Google Gemini", "Ollama"];
---

<section class="fade-in-up border-y border-border/60 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <p class="mb-8 text-center text-sm text-muted-foreground/70">
      Funciona com os modelos que você já usa
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      {
        providers.map((name) => (
          <span class="rounded-md border border-border bg-secondary px-5 py-2 text-sm font-medium text-secondary-foreground transition-colors duration-200 hover:border-primary/30 hover:text-foreground">
            {name}
          </span>
        ))
      }
    </div>
  </div>
</section>

---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import TerminalDemo from "../components/TerminalDemo.astro";
import Features from "../components/Features.astro";
import Providers from "../components/Providers.astro";
import Install from "../components/Install.astro";
import Newsletter from "../components/Newsletter.astro";
import Footer from "../components/Footer.astro";
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>pr-tools — AI-powered PR tools para devs no Azure DevOps</title>
    <meta
      name="description"
      content="CLI tools para gerar descrições de PR e cards de teste automaticamente no Azure DevOps. Suporta OpenRouter, Groq, Gemini e Ollama."
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="pr-tools — AI-powered PR tools para devs no Azure DevOps" />
    <meta
      property="og:description"
      content="CLI tools para gerar descrições de PR e cards de teste automaticamente no Azure DevOps. Suporta OpenRouter, Groq, Gemini e Ollama."
    />
    <meta property="og:image" content="/api/og" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="pr-tools" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="pr-tools — AI-powered PR tools para devs no Azure DevOps" />
    <meta
      name="twitter:description"
      content="CLI tools para gerar descrições de PR e cards de teste automaticamente no Azure DevOps. Suporta OpenRouter, Groq, Gemini e Ollama."
    />
    <meta name="twitter:image" content="/api/og" />

    <!-- Additional SEO -->
    <meta name="author" content="pr-tools" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://pr-tools.dev" />
    <meta name="theme-color" content="#0f1114" />
  </head>
  <body class="noise-overlay">
    <Navbar />
    <main>
      <Hero />
      <TerminalDemo />
      <Features />
      <Providers />
      <Install />
      <Newsletter />
    </main>
    <Footer />

    <!-- Scroll-entry animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
      );

      document.querySelectorAll(".fade-in-up").forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
